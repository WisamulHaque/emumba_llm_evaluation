RETRIEVAL_EVAL_INPUT=examples/rag/input/sample_input.json
RETRIEVAL_EVAL_OUTPUT=examples/rag/results/retrieval_results.jsonl
RETRIEVAL_EVAL_THRESHOLD=0.5
RETRIEVAL_EVAL_MODEL=all-MiniLM-L6-v2

RESPONSE_EVAL_PROVIDER=groq        # anthropic | openai | groq
RESPONSE_EVAL_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
RESPONSE_EVAL_API_KEY=<your-api-key-here>
RESPONSE_EVAL_THRESHOLD=0.5
RESPONSE_EVAL_INPUT=examples/rag/input/answer_sample_input.json
RESPONSE_EVAL_OUTPUT=examples/rag/results/response_results.jsonl
RESPONSE_ACCURACY_EVAL_OUTPUT=examples/rag/results/response_accuracy_results.jsonl
RESPONSE_FAITHFULNESS_EVAL_OUTPUT=examples/rag/results/response_faithfulness_results.jsonl
RESPONSE_INTENT_EVAL_OUTPUT=examples/rag/results/response_intent_results.jsonl
RESPONSE_COMPLETENESS_EVAL_OUTPUT=examples/rag/results/response_completeness_results.jsonl

GUARDRAILS_PROVIDER=openai_moderation   # openai_moderation | llamaguard
GUARDRAILS_API_KEY=<your-api-key-here>
LLAMAGUARD_MODEL=meta-llama/llama-guard-4-12b
GUARDRAILS_SCORE_THRESHOLD=0.7          # optional, openai_moderation only
GUARDRAILS_INPUT=examples/common/input/guardrails_input.json
GUARDRAILS_OUTPUT=examples/common/results/guardrails_results.jsonl

INJECTION_PROVIDER=groq              # anthropic | openai | groq
INJECTION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
INJECTION_API_KEY=<your-api-key-here>
INJECTION_INPUT=examples/common/input/prompt_injection_input.json
INJECTION_OUTPUT=examples/common/results/prompt_injection_results.jsonl

OUT_OF_SCOPE_PROVIDER=groq              # anthropic | openai | groq
OUT_OF_SCOPE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OUT_OF_SCOPE_API_KEY=<your-api-key-here>
OUT_OF_SCOPE_INPUT=examples/common/input/out_of_scope_input.json
OUT_OF_SCOPE_OUTPUT=examples/common/results/out_of_scope_results.jsonl

CONSISTENCY_PROVIDER=groq              # anthropic | openai | groq
CONSISTENCY_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
CONSISTENCY_API_KEY=<your-api-key-here>
CONSISTENCY_INPUT=examples/common/input/consistency_input.json
CONSISTENCY_OUTPUT=examples/common/results/consistency_results.jsonl


